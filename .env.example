# ── Twilio (SMS alerts) ──────────────────────────────────────────────────────
# Get these from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15551234567   # the Twilio number you purchased
ALERT_PHONE_NUMBER=+15559876543   # your personal mobile number

# ── SendGrid (email alerts + daily report) ───────────────────────────────────
# Get API key from app.sendgrid.com → Settings → API Keys
# Free tier: 100 emails/day forever
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=alerts@yourdomain.com  # must be a verified sender in SendGrid
TO_EMAIL=you@gmail.com            # where to receive alerts

# ── Optional overrides ───────────────────────────────────────────────────────
STATE_FILE=state.json             # path to the persistent state file
